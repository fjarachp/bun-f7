# =============================================================================
# Single source of truth for local environment variables.
#
# Copy this file to `.env.local` (gitignored) and fill in the blanks. Every app
# and package reads these values through the repo-root scripts
# (`dotenv -e .env.local -- turbo run …`); each workspace keeps a `.env.local`
# symlink → ../../.env.local so Vite, Bun, and drizzle-kit resolve the same
# values from any cwd. Do NOT add per-package `.env` files.
#
# Recreate the workspace symlinks locally with:
#   ln -sf ../../.env.local apps/server/.env.local
#   ln -sf ../../.env.local apps/store/.env.local
#   ln -sf ../../.env.local apps/admin/.env.local
#   ln -sf ../../.env.local packages/db/.env.local
# =============================================================================

# Server
SERVER_PORT=3035
SERVER_HOST=localhost

# Database — used by drizzle-kit (db:push) and the server runtime
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chp

# Auth (Better Auth)
AUTH_SECRET=your-auth-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3035
# Shared parent domain for cross-subdomain session cookies, e.g. ".example.com".
# Leave EMPTY for local dev — cookies stay host-only on localhost (no behavior
# change). Set it in prod when store/admin/api live on sibling subdomains so a
# single session cookie is shared across them. See packages/auth/README.md.
AUTH_COOKIE_DOMAIN=

# Frontend URLs — CORS trusted origins + auth trusted origins
PUBLIC_URL_STORE=http://localhost:3000
PUBLIC_URL_ADMIN=http://localhost:3001

# Frontend (Vite) — VITE_* are inlined into the store/admin client bundles
VITE_API_URL=http://localhost:3035

# Email (SendGrid) — optional; email features are gated on these being set
EMAIL_API_KEY=
EMAIL_API_URL=
EMAIL_FROM=
EMAIL_REPLY_TO=
SENDGRID_API_KEY=
SENDGRID_EVENT_WEBHOOK_SIGNING_KEY=
