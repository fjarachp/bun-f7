{
  "name": "store",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsgo --noEmit",
    "start": "bun .output/server/index.mjs",
    "lint": "oxlint -c ../../.oxlintrc.json .",
    "lint:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "lint:fix:unsafe": "oxlint -c ../../.oxlintrc.json --fix-dangerously .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:unsafe": "bun run lint:fix:unsafe && bun run format",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf .output node_modules dist .turbo .tanstack"
  },
  "dependencies": {
    "@hookform/resolvers": "catalog:",
    "@lingui/core": "catalog:",
    "@lingui/react": "catalog:",
    "@repo/api": "*",
    "@repo/auth": "*",
    "@repo/db": "*",
    "@repo/helpers": "*",
    "@repo/i18n": "*",
    "@repo/ui": "*",
    "@t3-oss/env-core": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-with-query": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "lucide-react": "catalog:",
    "next-themes": "catalog:",
    "nitro": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "sonner": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@lingui/babel-plugin-lingui-macro": "catalog:",
    "@lingui/vite-plugin": "catalog:",
    "@repo/typescript-config": "*",
    "@rolldown/plugin-babel": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "autoprefixer": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
