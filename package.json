{
  "name": "chp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@typescript/native-preview": "7.0.0-dev.20260623.1",
      "typescript": "^6.0.3",
      "@types/bun": "latest",
      "@types/node": "^26.0.0",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3",
      "zod": "^4.4.3",
      "tailwindcss": "^4.3.1",
      "@tailwindcss/vite": "^4.3.1",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "drizzle-orm": "1.0.0-rc.3",
      "drizzle-kit": "1.0.0-rc.3",
      "effect": "4.0.0-beta.78",
      "@effect/sql-pg": "4.0.0-beta.78",
      "pg": "^8.22.0",
      "@types/pg": "^8.20.0",
      "dotenv-cli": "^11.0.0",
      "better-auth": "^1.6.20",
      "@better-auth/cli": "^1.4.21",
      "@trpc/client": "^11.18.0",
      "@trpc/server": "^11.18.0",
      "@trpc/tanstack-react-query": "^11.18.0",
      "vite": "^8.1.0",
      "@vitejs/plugin-react": "^6.0.3",
      "autoprefixer": "^10.5.1",
      "superjson": "^2.2.6",
      "url-join": "^5.0.0",
      "@tanstack/react-query": "^5.101.1",
      "@tanstack/react-query-devtools": "^5.101.1",
      "@tanstack/react-router": "^1.170.16",
      "@tanstack/react-router-devtools": "^1.167.0",
      "@tanstack/react-router-with-query": "^1.130.17",
      "@tanstack/react-start": "^1.168.26",
      "react-hook-form": "^7.80.0",
      "@hookform/resolvers": "^5.4.0",
      "sonner": "^2.0.7",
      "nitro": "^3.0.260610-beta",
      "@t3-oss/env-core": "^0.13.11",
      "date-fns": "^4.4.0",
      "motion": "^12.41.0",
      "@babel/core": "^8.0.1",
      "@lingui/babel-plugin-lingui-macro": "^6.4.0",
      "@lingui/cli": "^6.4.0",
      "@lingui/conf": "^6.4.0",
      "@lingui/core": "^6.4.0",
      "@lingui/react": "^6.4.0",
      "@lingui/vite-plugin": "^6.4.0",
      "@rolldown/plugin-babel": "^0.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "build": "dotenv -e .env.local -- turbo run build",
    "dev": "dotenv -e .env.local -- turbo run dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:fix:unsafe": "oxlint --fix-dangerously .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:unsafe": "bun run lint:fix:unsafe && bun run format",
    "lingui:extract": "lingui extract --clean",
    "lingui:compile": "lingui compile && oxfmt --write packages/i18n/src/locales",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:push": "dotenv -e .env.local -- turbo run db:push",
    "db:migrate": "dotenv -e .env.local -- turbo run db:migrate",
    "db:generate": "dotenv -e .env.local -- turbo run db:generate",
    "db:studio": "dotenv -e .env.local -- turbo run db:studio",
    "docker:build": "turbo run docker:build",
    "docker:build:server": "docker build -t chp-server -f apps/server/Dockerfile .",
    "docker:build:store": "docker build -t chp-store -f apps/store/Dockerfile .",
    "docker:build:admin": "docker build -t chp-admin -f apps/admin/Dockerfile .",
    "docker:run:server": "docker run --env-file .env.local -e SERVER_HOST=0.0.0.0 -p 3035:3035 chp-server",
    "docker:run:store": "docker run --env-file .env.local -p 3000:3000 chp-store",
    "docker:run:admin": "docker run --env-file .env.local -p 3001:3001 chp-admin",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "@lingui/cli": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260623.1",
    "dotenv-cli": "catalog:",
    "husky": "^9.1.7",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "turbo": "^2.9.18",
    "typescript": "catalog:"
  },
  "overrides": {
    "drizzle-kit": "1.0.0-rc.3",
    "drizzle-orm": "1.0.0-rc.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.{json,jsonc,css,scss,md,mdx,yml,yaml,toml,html}": [
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14"
}
