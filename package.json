{
  "name": "mono",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@typescript/native-preview": "7.0.0-dev.20260501.1",
      "typescript": "^6.0.3",
      "@types/bun": "latest",
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "zod": "^4.4.2",
      "tailwindcss": "^4.2.4",
      "@tailwindcss/vite": "^4.2.4",
      "lucide-react": "^1.14.0",
      "next-themes": "^0.4.6",
      "drizzle-orm": "1.0.0-rc.1",
      "drizzle-kit": "1.0.0-rc.1",
      "effect": "4.0.0-beta.59",
      "@effect/sql-pg": "4.0.0-beta.59",
      "pg": "^8.20.0",
      "@types/pg": "^8.20.0",
      "dotenv-cli": "^11.0.0",
      "better-auth": "^1.6.9",
      "@better-auth/cli": "^1.4.21",
      "@trpc/client": "^11.17.0",
      "@trpc/server": "^11.17.0",
      "@trpc/tanstack-react-query": "^11.17.0",
      "vite": "^8.0.10",
      "superjson": "^2.2.6",
      "url-join": "^5.0.0",
      "@tanstack/react-query": "^5.100.7",
      "@tanstack/react-query-devtools": "^5.100.7",
      "@tanstack/react-router": "^1.169.1",
      "@tanstack/react-router-devtools": "^1.166.13",
      "@tanstack/react-router-with-query": "^1.130.17",
      "@tanstack/react-start": "^1.167.59",
      "react-hook-form": "^7.74.0",
      "@hookform/resolvers": "^5.2.2",
      "sonner": "^2.0.7",
      "nitro": "^3.0.260429-beta",
      "@t3-oss/env-core": "^0.13.11",
      "date-fns": "^4.1.0",
      "motion": "^12.38.0",
      "@babel/core": "^7.29.0",
      "@lingui/babel-plugin-lingui-macro": "^6.0.1",
      "@lingui/cli": "^6.0.1",
      "@lingui/conf": "^6.0.1",
      "@lingui/core": "^6.0.1",
      "@lingui/react": "^6.0.1",
      "@lingui/vite-plugin": "^6.0.1",
      "@rolldown/plugin-babel": "^0.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "build": "dotenv -e .env.local -- turbo run build",
    "dev": "dotenv -e .env.local -- turbo run dev",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:fix:unsafe": "oxlint --fix-dangerously .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:unsafe": "bun run lint:fix:unsafe && bun run format",
    "lingui:extract": "lingui extract --clean",
    "lingui:compile": "lingui compile && oxfmt --write packages/i18n/src/locales",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:push": "dotenv -e .env.local -- turbo run db:push",
    "db:migrate": "dotenv -e .env.local -- turbo run db:migrate",
    "db:generate": "dotenv -e .env.local -- turbo run db:generate",
    "db:studio": "dotenv -e .env.local -- turbo run db:studio",
    "docker:build": "turbo run docker:build",
    "docker:build:server": "docker build -t mono-server -f apps/server/Dockerfile .",
    "docker:build:store": "docker build -t mono-store -f apps/store/Dockerfile .",
    "docker:build:admin": "docker build -t mono-admin -f apps/admin/Dockerfile .",
    "docker:run:server": "docker run -p 3005:3005 mono-server",
    "docker:run:store": "docker run -p 3000:3000 mono-store",
    "docker:run:admin": "docker run -p 3001:3001 mono-admin",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "@lingui/cli": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260501.1",
    "dotenv-cli": "catalog:",
    "husky": "^9.1.7",
    "lefthook": "^2.1.6",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "turbo": "^2.9.7",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.{json,jsonc,css,scss,md,mdx,yml,yaml,toml,html}": [
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.13"
}
