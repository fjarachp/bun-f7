{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./effect": {
      "types": "./src/effect.ts",
      "default": "./src/effect.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    }
  },
  "scripts": {
    "dev": "tsgo --build",
    "build": "tsgo --build",
    "lint": "oxlint -c ../../.oxlintrc.json .",
    "lint:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "lint:fix:unsafe": "oxlint -c ../../.oxlintrc.json --fix-dangerously .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:unsafe": "bun run lint:fix:unsafe && bun run format",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf node_modules dist .turbo .cache",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/seed.ts"
  },
  "dependencies": {
    "@effect/sql-pg": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^25.6.0",
    "@types/pg": "catalog:",
    "@typescript/native-preview": "catalog:",
    "dotenv-cli": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
