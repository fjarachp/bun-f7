{
  "name": "@repo/email",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./locale": {
      "types": "./src/locale.ts",
      "default": "./src/locale.ts"
    },
    "./render": {
      "types": "./src/render.ts",
      "default": "./src/render.ts"
    },
    "./sendgrid": {
      "types": "./src/sendgrid.ts",
      "default": "./src/sendgrid.ts"
    },
    "./templates/welcome": {
      "types": "./src/templates/welcome.ts",
      "default": "./src/templates/welcome.ts"
    },
    "./welcome": {
      "types": "./src/welcome.ts",
      "default": "./src/welcome.ts"
    }
  },
  "scripts": {
    "dev": "email dev --port 3003",
    "build": "tsgo --noEmit",
    "preview": "email preview",
    "export": "email export",
    "lint": "oxlint -c ../../.oxlintrc.json .",
    "lint:fix": "oxlint -c ../../.oxlintrc.json --fix .",
    "lint:fix:unsafe": "oxlint -c ../../.oxlintrc.json --fix-dangerously .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:unsafe": "bun run lint:fix:unsafe && bun run format",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf node_modules dist .turbo .cache .react-email out"
  },
  "dependencies": {
    "@lingui/core": "catalog:",
    "@repo/i18n": "workspace:*",
    "@sendgrid/mail": "^8.1.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-email": "6.6.4"
  },
  "devDependencies": {
    "@react-email/ui": "6.6.4",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  }
}
